generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id               String             @id @default(uuid())
  name             String
  slug             String             @unique
  cnpj             String?
  city             String
  state            String
  active           Boolean            @default(true)
  createdAt        DateTime           @default(now())
  users                User[]
  patients             Patient[]
  drivers              Driver[]
  vehicles             Vehicle[]
  queues               OperationalQueue[]
  routes               Route[]
  trips                Trip[]
  checkpoints          Checkpoint[]
  auditLogs            AuditLog[]
  dailyOperations      DailyOperation[]
  operationShifts      OperationShift[]
  vehicleTrackings     VehicleTracking[]
  healthcareLocations  HealthcareLocation[]
}

model User {
  id         String   @id @default(uuid())
  tenantId   String
  name       String
  email      String
  password   String
  phone      String?
  role       Role
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  driver     Driver?

  @@unique([tenantId, email])
  @@index([tenantId])
}

enum Role {
  ADMIN
  OPERATOR
  COORDINATOR
  SUPERVISOR
  ADMIN_PREFEITURA
  DRIVER
  VIEWER
}

model Patient {
  id                String        @id @default(uuid())
  tenantId          String
  name              String
  cpf               String
  birthDate         DateTime
  phone             String?
  address           String
  lat               Float?
  lng               Float?
  mobility          MobilityType
  clinicalRisk      RiskLevel
  recurrent         Boolean       @default(false)
  notes             String?
  qrCode            String?       @unique
  operationalId     String?       @unique
  // QR Code seguro (LGPD) — token criptográfico, nunca contém CPF
  qrToken           String?       @unique
  qrIssuedAt        DateTime?
  qrActive          Boolean       @default(false)
  qrLastReadAt      DateTime?
  // Companion / Acompanhante
  requiresCompanion Boolean       @default(false)
  companionName     String?
  companionDocument String?
  companionPhone    String?
  createdAt         DateTime      @default(now())
  tenant            Tenant        @relation(fields: [tenantId], references: [id])
  queues            OperationalQueue[]
  trips             Trip[]
  qrAccessLogs      PatientQrAccessLog[]

  @@unique([tenantId, cpf])
  @@index([tenantId])
  @@index([qrToken])
}

enum MobilityType {
  NORMAL
  WHEELCHAIR
  STRETCHER
  OXYGEN
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Driver {
  id         String       @id @default(uuid())
  tenantId   String
  userId     String       @unique
  cnh        String
  cnhExpiry  DateTime
  active     Boolean      @default(true)
  lat        Float?
  lng        Float?
  status     DriverStatus
  tenant     Tenant       @relation(fields: [tenantId], references: [id])
  user       User         @relation(fields: [userId], references: [id])
  routes     Route[]
  checkpoints Checkpoint[]

  @@index([tenantId])
}

enum DriverStatus {
  AVAILABLE
  ON_ROUTE
  OFFLINE
  REST
}

model Vehicle {
  id               String          @id @default(uuid())
  tenantId         String
  plate            String          @unique
  model            String
  type             VehicleType
  capacity         Int
  wheelchair       Boolean         @default(false)
  stretcher        Boolean         @default(false)
  active           Boolean         @default(true)
  status           VehicleStatus
  tenant           Tenant          @relation(fields: [tenantId], references: [id])
  routes           Route[]
  trackings        VehicleTracking[]

  @@index([tenantId])
}

enum VehicleType {
  VAN
  BUS
  AMBULANCE
  CAR
  ADAPTED
}

enum VehicleStatus {
  AVAILABLE
  ON_ROUTE
  MAINTENANCE
  INACTIVE
}

model OperationalQueue {
  id                     String              @id @default(uuid())
  tenantId               String
  patientId              String
  appointmentDate        DateTime
  destination            String?
  healthcareLocationId   String?
  lat                    Float?
  lng                    Float?
  priority               QueuePriority
  status                 QueueStatus
  queueType              QueueType           @default(LOGISTICS)
  notes                  String?
  // Confirmação operacional
  confirmationStatus     ConfirmationStatus  @default(PENDING)
  confirmedAt            DateTime?
  confirmationChannel    ConfirmationChannel @default(MANUAL)
  confirmationAttempts   Int                 @default(0)
  lastContactAt          DateTime?
  // Recorrência de tratamento
  recurrenceType         RecurrenceType?
  recurrenceDays         String?             // JSON array de dias: "[1,3,5]" (0=dom … 6=sáb)
  recurrenceInterval     Int?                @default(1)
  recurrenceEndDate      DateTime?
  createdAt              DateTime            @default(now())
  tenant                 Tenant              @relation(fields: [tenantId], references: [id])
  patient                Patient             @relation(fields: [patientId], references: [id])
  healthcareLocation     HealthcareLocation? @relation(fields: [healthcareLocationId], references: [id])

  @@index([tenantId])
  @@index([patientId])
  @@index([confirmationStatus])
  @@index([healthcareLocationId])
}

enum QueueType {
  MEDICAL
  LOGISTICS
}

enum ConfirmationStatus {
  PENDING
  CONFIRMED
  CANCELED
  UNREACHABLE
  WAITING_MANUAL_CONFIRMATION
}

enum ConfirmationChannel {
  TELEGRAM
  WHATSAPP
  SMS
  PHONE_CALL
  MANUAL
}

enum RecurrenceType {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum QueuePriority {
  CRITICAL
  HIGH
  NORMAL
  PENDING
}

enum QueueStatus {
  WAITING
  ASSIGNED
  CONFIRMED
  CANCELLED
}

model Route {
  id                String      @id @default(uuid())
  tenantId          String
  driverId          String
  vehicleId         String
  date              DateTime
  origin            String
  destination       String
  status            RouteStatus
  waypoints         Json?
  estimatedKm       Float?
  estimatedDuration Int?
  createdAt         DateTime    @default(now())
  tenant            Tenant      @relation(fields: [tenantId], references: [id])
  driver            Driver      @relation(fields: [driverId], references: [id])
  vehicle           Vehicle     @relation(fields: [vehicleId], references: [id])
  trips             Trip[]
  checkpoints       Checkpoint[]

  @@index([tenantId])
}

enum RouteStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

model Trip {
  id          String     @id @default(uuid())
  tenantId    String
  routeId     String
  patientId   String
  status      TripStatus
  boardedAt   DateTime?
  completedAt DateTime?
  qrScanned   Boolean    @default(false)
  notes       String?
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  route       Route      @relation(fields: [routeId], references: [id])
  patient     Patient    @relation(fields: [patientId], references: [id])
  checkpoints Checkpoint[]

  @@index([tenantId])
}

enum TripStatus {
  SCHEDULED
  CONFIRMED
  BOARDED
  IN_PROGRESS
  COMPLETED
  NO_SHOW
  CANCELLED
}

model Checkpoint {
  id        String         @id @default(uuid())
  tenantId  String
  tripId    String
  routeId   String
  type      CheckpointType
  lat       Float
  lng       Float
  address   String?
  timestamp DateTime       @default(now())
  driverId  String
  tenant    Tenant         @relation(fields: [tenantId], references: [id])
  trip      Trip           @relation(fields: [tripId], references: [id])
  route     Route          @relation(fields: [routeId], references: [id])
  driver    Driver         @relation(fields: [driverId], references: [id])

  @@index([tenantId])
}

enum CheckpointType {
  DEPARTURE
  PICKUP
  DROP_OFF
  ARRIVAL
  BREAK
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  action    String
  entity    String
  entityId  String
  before    Json?
  after     Json?
  ip        String?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Vehicle Tracking — separado do motorista; pertence ao veículo e à rota
// ---------------------------------------------------------------------------
model VehicleTracking {
  id        String   @id @default(uuid())
  tenantId  String
  vehicleId String
  routeId   String?
  lat       Float
  lng       Float
  speed     Float?   // km/h
  heading   Float?   // graus 0–360
  accuracy  Float?   // metros
  ignition  Boolean  @default(false)
  online    Boolean  @default(true)
  timestamp DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([tenantId])
  @@index([vehicleId])
  @@index([routeId])
}

// ---------------------------------------------------------------------------
// DailyOperation — operação do dia (prefeitura pensa em "operação diária")
// ---------------------------------------------------------------------------
model DailyOperation {
  id              String          @id @default(uuid())
  tenantId        String
  date            DateTime
  status          OperationStatus @default(PLANNING)
  totalVehicles   Int             @default(0)
  totalDrivers    Int             @default(0)
  totalPatients   Int             @default(0)
  totalRoutes     Int             @default(0)
  notes           String?
  createdAt       DateTime        @default(now())
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  shifts          OperationShift[]

  @@unique([tenantId, date])
  @@index([tenantId])
}

enum OperationStatus {
  PLANNING
  ACTIVE
  CLOSED
  CANCELLED
}

// ---------------------------------------------------------------------------
// OperationShift — turno operacional (manhã, tarde, noite, integral)
// ---------------------------------------------------------------------------
model OperationShift {
  id               String         @id @default(uuid())
  tenantId         String
  dailyOperationId String
  name             String
  startTime        String         // "06:00"
  endTime          String         // "12:00"
  status           ShiftStatus    @default(PENDING)
  createdAt        DateTime       @default(now())
  tenant           Tenant         @relation(fields: [tenantId], references: [id])
  dailyOperation   DailyOperation @relation(fields: [dailyOperationId], references: [id])

  @@index([tenantId])
  @@index([dailyOperationId])
}

enum ShiftStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

// ---------------------------------------------------------------------------
// HealthcareLocation — destinos médicos padronizados (hospitais, clínicas, etc.)
// ---------------------------------------------------------------------------
model HealthcareLocation {
  id           String                       @id @default(uuid())
  tenantId     String
  name         String
  type         HealthcareLocationType
  address      String
  number       String?
  district     String?
  city         String
  state        String
  zipCode      String?
  latitude     Float?
  longitude    Float?
  contactPhone String?
  active       Boolean                      @default(true)
  notes        String?
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt
  tenant       Tenant                       @relation(fields: [tenantId], references: [id])
  specialties  HealthcareLocationSpecialty[]
  queues       OperationalQueue[]

  @@index([tenantId])
  @@index([type])
  @@index([active])
}

enum HealthcareLocationType {
  HOSPITAL
  CLINIC
  LAB
  UBS
  SPECIALTY_CENTER
  HEMODIALYSIS
  ONCOLOGY_CENTER
}

model HealthcareLocationSpecialty {
  id                   String             @id @default(uuid())
  healthcareLocationId String
  specialty            String
  healthcareLocation   HealthcareLocation @relation(fields: [healthcareLocationId], references: [id], onDelete: Cascade)

  @@index([healthcareLocationId])
  @@index([specialty])
}

// ---------------------------------------------------------------------------
// PatientQrAccessLog — rastreabilidade e antifraude de leituras de QR Code
// ---------------------------------------------------------------------------
model PatientQrAccessLog {
  id         String   @id @default(uuid())
  tenantId   String
  patientId  String
  qrToken    String
  scannedAt  DateTime @default(now())
  ip         String?
  device     String?
  vehicleId  String?
  checkpoint String?
  patient    Patient  @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([qrToken])
  @@index([scannedAt])
  @@index([tenantId])
}

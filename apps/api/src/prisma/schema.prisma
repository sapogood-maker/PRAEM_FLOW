generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id               String             @id @default(uuid())
  name             String
  slug             String             @unique
  cnpj             String?
  city             String
  state            String
  active           Boolean            @default(true)
  createdAt        DateTime           @default(now())
  users                User[]
  patients             Patient[]
  drivers              Driver[]
  vehicles             Vehicle[]
  queues               OperationalQueue[]
  routes               Route[]
  trips                Trip[]
  checkpoints          Checkpoint[]
  auditLogs            AuditLog[]
  dailyOperations      DailyOperation[]
  operationShifts      OperationShift[]
  vehicleTrackings     VehicleTracking[]
  healthcareLocations  HealthcareLocation[]
  devices              Device[]
  geoFenceEvents       GeoFenceEvent[]
}

model User {
  id         String   @id @default(uuid())
  tenantId   String
  name       String
  email      String
  password   String
  phone      String?
  role       Role
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  driver       Driver?

  @@unique([tenantId, email])
  @@index([tenantId])
}

enum Role {
  ADMIN
  OPERATOR
  COORDINATOR
  SUPERVISOR
  ADMIN_PREFEITURA
  DRIVER
  VIEWER
}

model Patient {
  id                String        @id @default(uuid())
  tenantId          String
  name              String
  cpf               String
  birthDate         DateTime
  phone             String?
  address           String
  lat               Float?
  lng               Float?
  mobility          MobilityType
  clinicalRisk      RiskLevel
  recurrent         Boolean       @default(false)
  notes             String?
  qrCode            String?       @unique
  operationalId     String?       @unique
  // QR Code seguro (LGPD) — token criptográfico, nunca contém CPF
  qrToken           String?       @unique
  qrIssuedAt        DateTime?
  qrActive          Boolean       @default(false)
  qrLastReadAt      DateTime?
  // QR hardening — only SHA-256 hash stored in DB, raw token lives only in QR image
  qrTokenHash       String?       @unique
  qrExpiresAt       DateTime?
  qrRevokedAt       DateTime?
  qrVersion         Int           @default(1)
  qrLastUsedAt      DateTime?
  // Companion / Acompanhante
  requiresCompanion Boolean       @default(false)
  companionName     String?
  companionDocument String?
  companionPhone    String?
  createdAt         DateTime      @default(now())
  tenant            Tenant        @relation(fields: [tenantId], references: [id])
  queues            OperationalQueue[]
  trips             Trip[]
  qrAccessLogs      PatientQrAccessLog[]
  tripTokens        TripToken[]

  @@unique([tenantId, cpf])
  @@index([tenantId])
  @@index([qrToken])
}

enum MobilityType {
  NORMAL
  WHEELCHAIR
  STRETCHER
  OXYGEN
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Driver {
  id               String       @id @default(uuid())
  tenantId         String
  userId           String       @unique
  cnh              String
  cnhExpiry        DateTime
  active           Boolean      @default(true)
  lat              Float?
  lng              Float?
  status           DriverStatus
  defaultVehicleId String?
  // Operational tracking timestamps
  wsLastSeenAt     DateTime?    // last time the tablet WebSocket joined/pinged
  lastHeartbeatAt  DateTime?    // last GPS heartbeat received from the tablet
  tenant           Tenant       @relation(fields: [tenantId], references: [id])
  user             User         @relation(fields: [userId], references: [id])
  routes           Route[]
  checkpoints      Checkpoint[]
  devices          Device[]

  @@index([tenantId])
  @@index([lastHeartbeatAt])
  @@index([wsLastSeenAt])
}

enum DriverStatus {
  AVAILABLE
  ON_ROUTE
  OFFLINE
  REST
}

model Vehicle {
  id               String          @id @default(uuid())
  tenantId         String
  plate            String          @unique
  model            String
  type             VehicleType
  capacity         Int
  wheelchair       Boolean         @default(false)
  stretcher        Boolean         @default(false)
  active           Boolean         @default(true)
  status           VehicleStatus
  tenant           Tenant          @relation(fields: [tenantId], references: [id])
  routes           Route[]
  trackings        VehicleTracking[]
  devices          Device[]

  @@index([tenantId])
}

enum VehicleType {
  VAN
  BUS
  AMBULANCE
  CAR
  ADAPTED
}

enum VehicleStatus {
  AVAILABLE
  ON_ROUTE
  BOARDING
  WAITING
  MAINTENANCE
  INACTIVE
  OFFLINE
}

model OperationalQueue {
  id                     String              @id @default(uuid())
  tenantId               String
  patientId              String
  appointmentDate        DateTime
  destination            String?
  healthcareLocationId   String?
  lat                    Float?
  lng                    Float?
  priority               QueuePriority
  status                 QueueStatus
  queueType              QueueType           @default(LOGISTICS)
  notes                  String?
  // Confirmação operacional
  confirmationStatus     ConfirmationStatus  @default(PENDING)
  confirmedAt            DateTime?
  confirmationChannel    ConfirmationChannel @default(MANUAL)
  confirmationAttempts   Int                 @default(0)
  lastContactAt          DateTime?
  // Recorrência de tratamento
  recurrenceType         RecurrenceType?
  recurrenceDays         String?             // JSON array de dias: "[1,3,5]" (0=dom … 6=sáb)
  recurrenceInterval     Int?                @default(1)
  recurrenceEndDate      DateTime?
  // ─── Timestamps operacionais (timeline do paciente) ───────────────────
  calledAt               DateTime?
  boardedAt              DateTime?
  departedAt             DateTime?
  arrivedAt              DateTime?
  cancelledAt            DateTime?
  noShowAt               DateTime?
  checkedInAt            DateTime?
  // ─── SLA operacional ──────────────────────────────────────────────────
  estimatedDepartureAt   DateTime?
  expectedArrivalAt      DateTime?
  slaMinutes             Int?                // limite SLA em minutos por prioridade
  slaStatus              QueueSlaStatus      @default(ON_TIME)
  estimatedWaitMinutes   Int?
  actualWaitMinutes      Int?
  delayMinutes           Int?
  // ─── No-show ─────────────────────────────────────────────────────────
  noShowReason           NoShowReason?
  createdAt              DateTime            @default(now())
  tenant                 Tenant              @relation(fields: [tenantId], references: [id])
  patient                Patient             @relation(fields: [patientId], references: [id])
  healthcareLocation     HealthcareLocation? @relation(fields: [healthcareLocationId], references: [id])

  @@index([tenantId])
  @@index([patientId])
  @@index([confirmationStatus])
  @@index([healthcareLocationId])
  @@index([status])
  @@index([slaStatus])
  @@index([priority])
}

enum QueueType {
  MEDICAL
  LOGISTICS
}

enum ConfirmationStatus {
  PENDING
  CONFIRMED
  CANCELED
  UNREACHABLE
  WAITING_MANUAL_CONFIRMATION
}

enum ConfirmationChannel {
  TELEGRAM
  WHATSAPP
  SMS
  PHONE_CALL
  MANUAL
}

enum RecurrenceType {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum QueuePriority {
  EMERGENCY
  CRITICAL
  HIGH
  NORMAL
  LOW
  PENDING
}

enum QueueStatus {
  WAITING
  CALLED
  CONFIRMED
  CHECKED_IN
  BOARDING
  IN_TRANSIT
  ARRIVED
  COMPLETED
  CANCELLED
  NO_SHOW
  ASSIGNED
  SCHEDULED
}

enum QueueSlaStatus {
  ON_TIME
  WARNING
  DELAYED
  CRITICAL
}

enum NoShowReason {
  NOT_FOUND
  CANCELLED
  REFUSED
  LATE
  UNKNOWN
}

model Route {
  id                      String       @id @default(uuid())
  tenantId                String
  driverId                String?      // optional — may be assigned later when scheduling
  vehicleId               String?      // optional — may be assigned later when scheduling
  date                    DateTime
  scheduledAt             DateTime?    // explicit dispatch/departure datetime for future routes
  origin                  String
  destination             String
  status                  RouteStatus  @default(SCHEDULED)
  dispatchType            DispatchType @default(IMMEDIATE)
  waypoints               Json?
  estimatedKm             Float?
  estimatedDuration       Int?
  // IA logistics fields — prepared for route optimization
  estimatedDistanceKm     Float?
  estimatedFuelCost       Float?
  routeOptimizationScore  Float?
  occupancyPrediction     Float?
  createdAt               DateTime     @default(now())
  tenant                  Tenant       @relation(fields: [tenantId], references: [id])
  driver                  Driver?      @relation(fields: [driverId], references: [id])
  vehicle                 Vehicle?     @relation(fields: [vehicleId], references: [id])
  trips                   Trip[]
  checkpoints             Checkpoint[]

  @@index([tenantId])
  @@index([scheduledAt])
}

enum RouteStatus {
  SCHEDULED
  PENDING
  PLANNED
  PREPARING
  DISPATCHED
  ACTIVE
  WAITING_CONSULTATION
  RETURNING
  COMPLETED
  CANCELLED
}

// DispatchStatus — logística operacional (separado do QueueStatus e ConnectionStatus)
enum DispatchStatus {
  PENDING_DISPATCH
  SCHEDULED
  ASSIGNED
  DISPATCHED
  BOARDING
  ACTIVE
  RETURNING
  COMPLETED
  CANCELLED
}

enum DispatchType {
  IMMEDIATE
  SCHEDULED
}

model Trip {
  id          String     @id @default(uuid())
  tenantId    String
  routeId     String
  patientId   String
  status      TripStatus
  boardedAt   DateTime?
  completedAt DateTime?
  qrScanned   Boolean    @default(false)
  notes       String?
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  route       Route      @relation(fields: [routeId], references: [id])
  patient     Patient    @relation(fields: [patientId], references: [id])
  checkpoints Checkpoint[]
  tokens      TripToken[]
  stops       TripStop[]

  @@index([tenantId])
}

enum TripStatus {
  SCHEDULED
  CONFIRMED
  BOARDING
  IN_PROGRESS
  ARRIVED
  COMPLETED
  NO_SHOW
  CANCELLED
}

model Checkpoint {
  id        String         @id @default(uuid())
  tenantId  String
  tripId    String
  routeId   String
  type      CheckpointType
  lat       Float
  lng       Float
  address   String?
  timestamp DateTime       @default(now())
  driverId  String
  tenant    Tenant         @relation(fields: [tenantId], references: [id])
  trip      Trip           @relation(fields: [tripId], references: [id])
  route     Route          @relation(fields: [routeId], references: [id])
  driver    Driver         @relation(fields: [driverId], references: [id])

  @@index([tenantId])
}

enum CheckpointType {
  DEPARTURE
  PICKUP
  DROP_OFF
  ARRIVAL
  BREAK
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  action    String
  entity    String
  entityId  String
  endpoint  String?
  method    String?
  deviceId  String?
  before    Json?
  after     Json?
  ip        String?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([entity])
}

// ---------------------------------------------------------------------------
// Vehicle Tracking — separado do motorista; pertence ao veículo e à rota
// ---------------------------------------------------------------------------
model VehicleTracking {
  id                    String                   @id @default(uuid())
  tenantId              String
  vehicleId             String
  routeId               String?
  driverId              String?
  lat                   Float
  lng                   Float
  speed                 Float?                   // km/h
  heading               Float?                   // graus 0–360
  accuracy              Float?                   // metros
  batteryLevel          Float?                   // 0–100 %
  signalStrength        Float?                   // dBm
  gpsSource             String?                  // GPS | NETWORK | FUSED
  ignition              Boolean                  @default(false)
  online                Boolean                  @default(true)
  operationalStatus     VehicleOperationalStatus @default(OFFLINE)
  lastHeartbeatAt       DateTime?
  lastMovementAt        DateTime?                // last time speed > 0
  timestamp             DateTime                 @default(now())
  tenant                Tenant                   @relation(fields: [tenantId], references: [id])
  vehicle               Vehicle                  @relation(fields: [vehicleId], references: [id])

  @@index([tenantId])
  @@index([vehicleId])
  @@index([routeId])
  @@index([operationalStatus])
  @@index([lastHeartbeatAt])
}

// ---------------------------------------------------------------------------
// VehicleOperationalStatus — derived from GPS + speed + heartbeat
// ---------------------------------------------------------------------------
enum VehicleOperationalStatus {
  ONLINE
  OFFLINE
  MOVING
  IDLE
  BOARDING
  WAITING
  ARRIVED
  MAINTENANCE
}

// ---------------------------------------------------------------------------
// GeoFenceEvent — prepared for automated geofence detection (hospital/UBS arrival)
// ---------------------------------------------------------------------------
model GeoFenceEvent {
  id                   String   @id @default(uuid())
  tenantId             String
  vehicleId            String
  routeId              String?
  tripId               String?
  eventType            String   // ARRIVED_AT_DESTINATION | LEFT_DESTINATION | ENTERED_ZONE | EXITED_ZONE
  locationId           String?  // HealthcareLocation id if applicable
  locationName         String?
  lat                  Float
  lng                  Float
  detectedAt           DateTime @default(now())
  tenant               Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([vehicleId])
  @@index([routeId])
}

// ---------------------------------------------------------------------------
// DailyOperation — operação do dia (prefeitura pensa em "operação diária")
// ---------------------------------------------------------------------------
model DailyOperation {
  id                   String          @id @default(uuid())
  tenantId             String
  date                 DateTime
  status               OperationStatus @default(PLANNING)
  totalVehicles        Int             @default(0)
  totalDrivers         Int             @default(0)
  totalPatients        Int             @default(0)
  totalRoutes          Int             @default(0)
  notes                String?
  createdAutomatically Boolean         @default(false)
  createdAt            DateTime        @default(now())
  tenant               Tenant          @relation(fields: [tenantId], references: [id])
  shifts               OperationShift[]

  @@unique([tenantId, date])
  @@index([tenantId])
}

enum OperationStatus {
  PLANNING
  ACTIVE
  CLOSED
  CANCELLED
}

// ---------------------------------------------------------------------------
// OperationShift — turno operacional (manhã, tarde, noite, integral)
// ---------------------------------------------------------------------------
model OperationShift {
  id               String         @id @default(uuid())
  tenantId         String
  dailyOperationId String
  name             String
  startTime        String         // "06:00"
  endTime          String         // "12:00"
  status           ShiftStatus    @default(PENDING)
  createdAt        DateTime       @default(now())
  tenant           Tenant         @relation(fields: [tenantId], references: [id])
  dailyOperation   DailyOperation @relation(fields: [dailyOperationId], references: [id])

  @@index([tenantId])
  @@index([dailyOperationId])
}

enum ShiftStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

// ---------------------------------------------------------------------------
// HealthcareLocation — destinos médicos padronizados (hospitais, clínicas, etc.)
// ---------------------------------------------------------------------------
model HealthcareLocation {
  id                    String                       @id @default(uuid())
  tenantId              String
  name                  String
  type                  HealthcareLocationType
  address               String
  number                String?
  district              String?
  city                  String
  state                 String
  zipCode               String?
  latitude              Float?
  longitude             Float?
  contactPhone          String?
  active                Boolean                      @default(true)
  notes                 String?
  // Google Maps / Geolocation integration
  googlePlaceId         String?
  geocodingValidated    Boolean                      @default(false)
  routeNotes            String?
  operationalArea       String?
  estimatedTravelMinutes Int?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  tenant                Tenant                       @relation(fields: [tenantId], references: [id])
  specialties           HealthcareLocationSpecialty[]
  queues                OperationalQueue[]
  tripStops             TripStop[]

  @@index([tenantId])
  @@index([type])
  @@index([active])
}

enum HealthcareLocationType {
  HOSPITAL
  CLINIC
  LAB
  UBS
  SPECIALTY_CENTER
  HEMODIALYSIS
  ONCOLOGY_CENTER
}

model HealthcareLocationSpecialty {
  id                   String             @id @default(uuid())
  healthcareLocationId String
  specialty            String
  healthcareLocation   HealthcareLocation @relation(fields: [healthcareLocationId], references: [id], onDelete: Cascade)

  @@index([healthcareLocationId])
  @@index([specialty])
}

// ---------------------------------------------------------------------------
// PatientQrAccessLog — rastreabilidade e antifraude de leituras de QR Code
// ---------------------------------------------------------------------------
model PatientQrAccessLog {
  id           String        @id @default(uuid())
  tenantId     String
  patientId    String
  qrToken      String
  // Audit & antifraude
  status       QrScanStatus  @default(SUCCESS)
  gpsLat       Float?
  gpsLng       Float?
  operatorId   String?
  tripId       String?
  routeId      String?
  source       QrScanSource  @default(API)
  scannedAt    DateTime      @default(now())
  ip           String?
  device       String?
  vehicleId    String?
  checkpoint   String?
  patient      Patient       @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([qrToken])
  @@index([scannedAt])
  @@index([tenantId])
  @@index([status])
}

enum QrScanStatus {
  SUCCESS
  INVALID
  EXPIRED
  REVOKED
  DUPLICATED
}

enum QrScanSource {
  TABLET
  TABLET_SMART_SCANNER
  TOTEM
  MOBILE
  API
}

// ---------------------------------------------------------------------------
// Device — dispositivos operacionais (tablets motoristas, totens, mobiles)
// ---------------------------------------------------------------------------
model Device {
  id            String      @id @default(uuid())
  tenantId      String
  name          String
  serialNumber  String?     @unique
  type          DeviceType
  platform      String?     // android | ios | web
  vehicleId     String?
  driverId      String?
  active        Boolean     @default(true)
  lastSeenAt    DateTime?
  appVersion    String?
  ipAddress     String?
  authToken     String?     @unique
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  vehicle       Vehicle?    @relation(fields: [vehicleId], references: [id])
  driver        Driver?     @relation(fields: [driverId], references: [id])

  @@index([tenantId])
  @@index([type])
  @@index([vehicleId])
  @@index([driverId])
}

enum DeviceType {
  TABLET
  TOTEM
  MOBILE
  DISPATCH
}

// ---------------------------------------------------------------------------
// PatientTransportStatus — ciclo de vida do transporte do paciente
// ---------------------------------------------------------------------------
enum PatientTransportStatus {
  WAITING
  CONFIRMED
  CHECKED_IN
  BOARDED
  IN_TRANSIT
  ARRIVED
  MISSED
}

// ---------------------------------------------------------------------------
// ConnectionStatus — presença online (WebSocket/dispositivo)
// ---------------------------------------------------------------------------
enum ConnectionStatus {
  ONLINE
  OFFLINE
  IDLE
}

// ---------------------------------------------------------------------------
// TripToken — tokens operacionais para confirmação, embarque, retorno, etc.
// Utilizados via QR Code, Telegram, links públicos.
// ---------------------------------------------------------------------------
model TripToken {
  id         String          @id @default(uuid())
  tenantId   String
  tripId     String
  patientId  String
  token      String          @unique @default(uuid())
  type       TripTokenType
  expiresAt  DateTime
  usedAt     DateTime?
  usedByIp   String?
  usedByGps  String?         // "lat,lng" quando disponível
  deviceInfo String?
  createdAt  DateTime        @default(now())
  trip       Trip            @relation(fields: [tripId], references: [id])
  patient    Patient         @relation(fields: [patientId], references: [id])

  @@index([token])
  @@index([tripId])
  @@index([patientId])
  @@index([tenantId])
  @@index([type])
}

enum TripTokenType {
  CONFIRMATION
  BOARDING
  RETURN
  REBOOK
}

// ---------------------------------------------------------------------------
// TripStop — paradas individuais de uma viagem (multi-stop route)
// ---------------------------------------------------------------------------

model TripStop {
  id             String         @id @default(uuid())
  tenantId       String
  tripId         String
  sequence       Int
  type           TripStopType
  locationId     String?
  name           String
  lat            Float?
  lng            Float?
  plannedArrival DateTime?
  actualArrival  DateTime?
  status         TripStopStatus @default(PENDING)
  notes          String?
  createdAt      DateTime       @default(now())
  trip           Trip           @relation(fields: [tripId], references: [id])
  location       HealthcareLocation? @relation(fields: [locationId], references: [id])

  @@index([tenantId])
  @@index([tripId])
  @@index([status])
  @@index([sequence])
}

enum TripStopType {
  PICKUP
  CLINIC
  HOSPITAL
  EXAM
  PHARMACY
  RETURN
  DROPOFF
}

enum TripStopStatus {
  PENDING
  EN_ROUTE
  ARRIVED
  BOARDING
  COMPLETED
  SKIPPED
}
